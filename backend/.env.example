# Backend
DATABASE_URL=sqlite:///./data/diagnostic_platform.db
SECRET_KEY=change-me-in-production-min-32-characters

# Evaluation — local AI (recommended for RTX 2050)
EVALUATION_PROVIDER=ollama
USE_OLLAMA_EVALUATION=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M
OLLAMA_EVAL_TEMPERATURE=0.2
OLLAMA_EVAL_TIMEOUT=600

# Dynamic question generation (template slot-filling for English grammar + Math)
DYNAMIC_QUESTIONS_ENABLED=true
DYNAMIC_VARIANTS_PER_TEMPLATE=6
RESOURCE_URL_VALIDATION=true
DEFAULT_STUDENT_GRADE=10
EVALUATION_ALLOW_RULE_FALLBACK=true

# Optional cloud fallback (off by default)
USE_MISTRAL_EVALUATION=false
MISTRAL_API_KEY=
